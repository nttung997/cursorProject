<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare"
    xmlns:xf="http://www.w3.org/2002/xforms">
<head>
    <w2:type>DEFAULT</w2:type>
    <w2:buildDate/>
    <xf:model>
        <w2:dataCollection baseNode="map">
            <w2:dataList id="{{DATA_LIST_ID}}" baseNode="list" repeatNode="map" valueAttribute="">
                <w2:columnInfo>
{{COLUMNS}}
                </w2:columnInfo>
            </w2:dataList>
        </w2:dataCollection>
        <w2:workflowCollection/>
        <xf:submission id="{{SUBMISSION_ID}}" ref="" target="data:json,{{DATA_LIST_ID}}"
            action="{{SUBMISSION_ACTION}}" method="get" mediatype="application/json" encoding="UTF-8"
            ev:submitdone="scwin.{{SUBMISSION_ID}}_submitdone"/>
    </xf:model>
    <script type="text/javascript"><![CDATA[
        scwin.onpageload = function () {
            $p.executeSubmission("{{SUBMISSION_ID}}");
        };

        scwin.{{SUBMISSION_ID}}_submitdone = function () {
            var count = {{DATA_LIST_ID}}.getRowCount();
            {{STATUS_TEXTBOX_ID}}.setValue("Loaded " + count + " rows.");
        };

        scwin.{{REFRESH_BUTTON_ID}}_onclick = function () {
            $p.executeSubmission("{{SUBMISSION_ID}}");
        };
    ]]></script>
</head>
<body ev:onpageload="scwin.onpageload">
    <xf:group id="grp_root" style="padding:16px;font-family:sans-serif;">
        <w2:textbox id="{{TITLE_TEXTBOX_ID}}" label="{{PAGE_TITLE}}"
            style="font-size:20px;font-weight:bold;margin-bottom:12px;"/>
        <w2:textbox id="{{STATUS_TEXTBOX_ID}}" label="Loading..."
            style="margin-bottom:12px;color:#555;"/>
        <xf:group id="grp_toolbar" style="margin-bottom:12px;">
            <xf:trigger id="{{REFRESH_BUTTON_ID}}" style="padding:6px 14px;">
                <xf:label>Refresh</xf:label>
                <ev:listener ev:event="onclick" ev:handler="scwin.{{REFRESH_BUTTON_ID}}_onclick"/>
            </xf:trigger>
        </xf:group>
        <w2:gridView id="{{GRID_ID}}" dataList="data:{{DATA_LIST_ID}}"
            style="width:100%;height:280px;" autoFit="allColumn" scrollByColumn="false">
            <w2:header id="hdr_main">
                <w2:row id="hdr_row">
{{HEADER_COLUMNS}}
                </w2:row>
            </w2:header>
            <w2:gBody id="gbody_main">
                <w2:row id="body_row">
{{BODY_COLUMNS}}
                </w2:row>
            </w2:gBody>
        </w2:gridView>
    </xf:group>
</body>
</html>
