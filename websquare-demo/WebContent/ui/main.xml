<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare"
    xmlns:xf="http://www.w3.org/2002/xforms">
<head>
    <w2:type>DEFAULT</w2:type>
    <w2:buildDate/>
    <xf:model>
        <w2:dataCollection baseNode="map">
            <w2:dataList id="dlt_employee" baseNode="list" repeatNode="map" valueAttribute="">
                <w2:columnInfo>
                    <w2:column id="id" name="ID" dataType="text"/>
                    <w2:column id="name" name="Name" dataType="text"/>
                    <w2:column id="department" name="Department" dataType="text"/>
                    <w2:column id="email" name="Email" dataType="text"/>
                </w2:columnInfo>
            </w2:dataList>
        </w2:dataCollection>
        <w2:workflowCollection/>
        <xf:submission id="sbm_loadEmployees" ref="" target="data:json,dlt_employee"
            action="/data/employees.json" method="get" mediatype="application/json" encoding="UTF-8"
            ev:submitdone="scwin.sbm_loadEmployees_submitdone"/>
    </xf:model>
    <script type="text/javascript"><![CDATA[
        scwin.onpageload = function () {
            $p.executeSubmission("sbm_loadEmployees");
        };

        scwin.sbm_loadEmployees_submitdone = function () {
            var count = dlt_employee.getRowCount();
            txb_status.setValue("Loaded " + count + " employees from employees.json.");
        };

        scwin.btn_refresh_onclick = function () {
            $p.executeSubmission("sbm_loadEmployees");
        };
    ]]></script>
</head>
<body ev:onpageload="scwin.onpageload">
    <xf:group id="grp_root" style="padding:16px;font-family:sans-serif;">
        <w2:textbox id="txb_title" label="WebSquare Demo — Employee List"
            style="font-size:20px;font-weight:bold;margin-bottom:12px;"/>
        <w2:textbox id="txb_status" label="Loading..."
            style="margin-bottom:12px;color:#555;"/>
        <xf:group id="grp_toolbar" style="margin-bottom:12px;">
            <xf:trigger id="btn_refresh" style="padding:6px 14px;">
                <xf:label>Refresh</xf:label>
                <ev:listener ev:event="onclick" ev:handler="scwin.btn_refresh_onclick"/>
            </xf:trigger>
        </xf:group>
        <w2:gridView id="grd_employee" dataList="data:dlt_employee"
            style="width:100%;height:280px;" autoFit="allColumn" scrollByColumn="false">
            <w2:header id="hdr_employee">
                <w2:row id="hdr_row">
                    <w2:column id="hdr_id" inputType="text" value="ID" width="80"/>
                    <w2:column id="hdr_name" inputType="text" value="Name" width="120"/>
                    <w2:column id="hdr_dept" inputType="text" value="Department" width="120"/>
                    <w2:column id="hdr_email" inputType="text" value="Email" width="200"/>
                </w2:row>
            </w2:header>
            <w2:gBody id="gbody_employee">
                <w2:row id="body_row">
                    <w2:column id="id" inputType="text" width="80" readOnly="true"/>
                    <w2:column id="name" inputType="text" width="120" readOnly="true"/>
                    <w2:column id="department" inputType="text" width="120" readOnly="true"/>
                    <w2:column id="email" inputType="text" width="200" readOnly="true"/>
                </w2:row>
            </w2:gBody>
        </w2:gridView>
    </xf:group>
</body>
</html>
